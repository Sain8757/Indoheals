NODE_ENV=development
PORT=5001

MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/indo-heals
JWT_SECRET=replace-with-a-long-random-secret
JWT_TTL=7d
ADMIN_EMAIL=admin@example.com

FRONTEND_URL=http://localhost:5500
BACKEND_PUBLIC_URL=http://localhost:5001
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,http://localhost:5173
RATE_LIMIT_MAX=300

RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=replace-with-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-webhook-secret

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=replace-with-smtp-password
MAIL_FROM="Indo Heals <no-reply@example.com>"

SECURE_DOWNLOAD_DIR=./secure-files
